# ─── секреты и данные (НИКОГДА в гит) ─────────────────────────────────────────
.env                # реальные BOT_TOKEN / ADMIN_ID / email-креды / ключи бэкапов
*.db                # bot.db — там ПРИВАТНЫЕ КЛЮЧИ управляемых устройств
*.db-wal
*.db-shm
*.db-journal
data/               # локальный AWG_BOT_DATA_DIR, если используешь
backups/            # снимки БД/конфига

# .env.example — НУЖЕН в репозитории (шаблон без секретов), НЕ игнорируется:
# паттерн ".env" матчит только файл ровно ".env", ".env.example" остаётся.

# ─── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ─── тесты / покрытие ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ─── сборка релизов (build_release.sh) ────────────────────────────────────────
dist/

# ─── ОС / редактор ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
# .vscode/          # раскомментируй, если не хочешь коммитить настройки VS Code
